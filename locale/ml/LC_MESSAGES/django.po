msgid "Register Account"
msgstr "അക്കൗണ്ട് രജിസ്റ്റർ ചെയ്യുക"

msgid "Easy Reporting"
msgstr "എളുപ്പത്തിലുള്ള റിപ്പോർട്ടിംഗ്"

msgid "Quickly submit complaints about infrastructure, sanitation, or safety in your locality."
msgstr "നിങ്ങളുടെ പ്രദേശത്തെ അടിസ്ഥാന സൗകര്യങ്ങൾ, ശുചിത്വം അല്ലെങ്കിൽ സുരക്ഷ എന്നിവയെക്കുറിച്ചുള്ള പരാതികൾ വേഗത്തിൽ സമർപ്പിക്കുക."

msgid "Real-time Tracking"
msgstr "തത്സമയ ട്രാക്കിംഗ്"

msgid "Monitor the status of your reports as they move from processing to resolution."
msgstr "നിങ്ങളുടെ റിപ്പോർട്ടുകളുടെ സ്റ്റാറ്റസ് പ്രോസസ്സിംഗ് മുതൽ പരിഹാരം വരെ നിരീക്ഷിക്കുക."

msgid "AI Routing"
msgstr "AI റൂട്ടിംഗ്"

msgid "Our automated classification system ensures your report reaches the correct department instantly."
msgstr "ഞങ്ങളുടെ ഓട്ടോമേറ്റഡ് ക്ലാസിഫിക്കേഷൻ സിസ്റ്റം നിങ്ങളുടെ റിപ്പോർട്ട് ഉടൻ തന്നെ ശരിയായ വകുപ്പിൽ എത്തുന്നുവെന്ന് ഉറപ്പാക്കുന്നു."

msgid "City Care - Smart City Automated Complaint Management System"
msgstr "സിറ്റി കെയർ - സ്മാർട്ട് സിറ്റി ഓട്ടോമേറ്റഡ് കംപ്ലൈന്റ് മാനേജ്മെന്റ് സിസ്റ്റം"

