msgid "Lodge a Complaint"
msgstr "ഒരു പരാതി സമർപ്പിക്കുക"

msgid "Back"
msgstr "തിരികെ"

msgid "Complaint Title"
msgstr "പരാതിയുടെ തലക്കെട്ട്"

msgid "Briefly describe the issue (e.g., \"Broken street light near Central Park\")."
msgstr "പ്രശ്നത്തെക്കുറിച്ച് ചുരുക്കത്തിൽ വിവരിക്കുക (ഉദാഹരണത്തിന്, \"സെൻട്രൽ പാർക്കിന് സമീപമുള്ള തകരാറിലായ തെരുവ് വിളക്ക്\")."

msgid "Detailed Description"
msgstr "വിശദമായ വിവരണം"

msgid "Location / Address"
msgstr "സ്ഥലം / വിലാസം"

msgid "Upload Photo (Optional)"
msgstr "ഫോട്ടോ അപ്‌ലോഡ് ചെയ്യുക (വേണമെങ്കിൽ)"

msgid "Supported formats: JPG, PNG. Max size: 5MB."
msgstr "പിന്തുണയ്ക്കുന്ന ഫോർമാറ്റുകൾ: JPG, PNG. പരമാവധി സൈസ്: 5MB."

msgid "Submit Official Complaint"
msgstr "ഔദ്യോഗിക പരാതി സമർപ്പിക്കുക"

msgid "By submitting, you agree that the information provided is accurate and truthful."
msgstr "സമർപ്പിക്കുന്നതിലൂടെ, നൽകിയിരിക്കുന്ന വിവരങ്ങൾ കൃത്യവും സത്യവുമാണെന്ന് നിങ്ങൾ സമ്മതിക്കുന്നു."

msgid "City Care"
msgstr "സിറ്റി കെയർ"

msgid "Home"
msgstr "പൂമുഖം"

msgid "City Care Assistant"
msgstr "സിറ്റി കെയർ അസിസ്റ്റന്റ്"

msgid "I'm your assistant. How can I help you today?"
msgstr "ഞാൻ നിങ്ങളുടെ അസിസ്റ്റന്റാണ്. ഇന്ന് എനിക്ക് എങ്ങനെ സഹായിക്കാനാകും?"

msgid "Type your message..."
msgstr "നിങ്ങളുടെ സന്ദേശം ടൈപ്പ് ചെയ്യുക..."

msgid "Sign In Instead"
msgstr "പകരം സൈൻ ഇൻ ചെയ്യുക"

